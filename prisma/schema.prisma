generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  passwordHash     String    
  role             String    // 'PM' (Chef de projet) or 'SM' (Chef d'équipe) or 'ADMIN'
  status           String    @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED'
  
  // RPG System
  xp               Int       @default(0)
  level            Int       @default(1)
  characterId      Int       @default(1) // 1-5
  
  // Company / Organization (for white-labeling)
  company          String?
  
  projectsAsPM     Project[] @relation("ProjectPM")
  projectsAsSM     Project[] @relation("ProjectSM")
  planTemplates    PlanTemplate[] @relation("templatesCreatedBy")
  userBadges       UserBadge[]
  
  // Cooking App Relations
  cookingProtocols CookingProtocol[] @relation("UserProtocols")
  pantryItems      PantryItem[]      @relation("UserPantry")
  mealPreps        MealPrep[]        @relation("UserMealPreps")
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Project {
  id               String    @id @default(cuid())
  name             String
  location         String?
  startDate        DateTime?
  endDate          DateTime?
  
  projectManagerId String
  projectManager   User      @relation("ProjectPM", fields: [projectManagerId], references: [id])
  
  siteManagerId    String?
  siteManager      User?     @relation("ProjectSM", fields: [siteManagerId], references: [id])
  
  subLocations     SubLocation[]
  tasks            Task[]
  weeklyPlans      WeeklyPlan[]
  revisions        RevisionLog[]
  dailyReports     DailyReport[]
  planTemplates    PlanTemplate[]
  
  // Hub module data
  planningMilestones PlanningMilestone[]
  monthlyUploads     MonthlyUpload[]
  purchaseCategories PurchaseCategory[]
  financeSnapshots   FinanceSnapshot[]
  etudeTasks         EtudeTask[]
  etudeDocuments     EtudeDocument[]
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ── Hub Module: Planning ──
model PlanningMilestone {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  category    String?
  startDate   DateTime
  endDate     DateTime
  progress    Float    @default(0)
  isComplete  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ── Hub Module: Monthly Upload Tracking ──
model MonthlyUpload {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  month          DateTime  // The month this upload represents
  purchasesFile  String?   // Original filename
  financesFile   String?
  etudesFile     String?
  uploadedById   String?
  uploadedAt     DateTime  @default(now())

  purchaseCategories PurchaseCategory[]
  financeSnapshots   FinanceSnapshot[]
  etudeTasks         EtudeTask[]
  etudeDocuments     EtudeDocument[]
}

// ── Hub Module: Purchases / Achats (from Synthèse sheet) ──
model PurchaseCategory {
  id                  String    @id @default(cuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId            String?
  upload              MonthlyUpload? @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  
  category            String    // "Tableaux électriques", "Éclairage", etc.
  peInitials          String?   // Initiales PE
  status              String?   // V, x, etc.
  isInterco           Boolean   @default(false)
  inProgress          Boolean   @default(false)
  
  offerPriceSoum      Float?    // Prix offre soumission
  commercialDiscount  Float?    // Remise commerciale
  hypothesisInjected  Float?    // Hypothèse injectée ODOO
  costPrice           Float?    // Prix de revient/achat
  supplierSoum        String?   // Fournisseur soumission
  supplierExe         String?   // Fournisseur exécution
  negotiatedPrice     Float?    // Prix achat Négocié
  returnAmount        Float?    // RETURN (margin gained)
  comments            String?   // Commentaires VRI/DCO
  
  createdAt           DateTime  @default(now())
}

// ── Hub Module: Finances / EoC (monthly snapshots) ──
model FinanceSnapshot {
  id                  String    @id @default(cuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId            String?
  upload              MonthlyUpload? @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  
  month               DateTime  // Which month this snapshot represents
  sheetName           String?   // Original sheet name for reference
  
  // Revenue
  totalRevenue        Float?    // Revenu total
  approvedSettlements Float?    // Règlements approuvés
  
  // Labor
  laborHours          Float?    // # heures des ouvriers
  laborHourlyRate     Float?    // taux horaire
  laborCost           Float?    // Total des charges salariales propres
  
  // External labor
  externalLaborCost   Float?    // Performance externe en régie
  
  // Subcontractors
  subcontractorCost   Float?    // Sous-traitance total
  
  // Materials
  materialCost        Float?    // Total achats matériel
  
  // Engineering / internal costs
  engineeringCost     Float?    // CA + IP + Dessinateurs total
  
  // Site costs
  siteCost            Float?    // Containers, tools, consumables
  
  // Provisions
  provisionsCost      Float?    // Garantie, impayés, litiges
  
  // Bottom line
  totalCost           Float?    
  result              Float?    // Résultat y compris révision
  marginPercent       Float?    // % margin
  
  // Workforce planning
  plannedWorkers      Int?
  plannedDays         Int?
  
  createdAt           DateTime  @default(now())
}

// ── Hub Module: Études / Document Tracking ──
model EtudeTask {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId        String?
  upload          MonthlyUpload? @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  // Parsed from 'Simple Gantt'
  wbs             String?  // The '#' column
  activity        String
  assignedTo      String?
  startDate       DateTime?
  endDate         DateTime?
  duration        Int?     // Jours
  status          String?  // Statut
  progress        Float?   // % réalisé

  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([uploadId])
}

model EtudeDocument {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId        String?
  upload          MonthlyUpload? @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  category        String   // 'materiel', 'plans', 'calculs'
  reference       String
  title           String
  revision        String?
  status          String?  // 'APP', 'BPE', 'ATT', etc
  
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([uploadId])
}

model SubLocation {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RevisionLog {
  id           String   @id @default(cuid())
  projectId    String
  fileName     String
  uploadedAt   DateTime @default(now())
  changesMade  String?  
  
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id                  String    @id @default(cuid())
  taskCode            String    
  status              String    @default("ACTIVE") 
  category            String    @default("Non Catégorisé")
  description         String
  unit                String    
  quantity            Float     
  completedQuantity   Float     @default(0) 
  minutesPerUnit      Float     
  
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  weeklyPlanTasks     WeeklyPlanTask[]
  dailyProgress       DailyTaskProgress[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([projectId, taskCode])
}

model WeeklyPlan {
  id                  String    @id @default(cuid())
  weekNumber          Int
  year                Int
  numberOfWorkers     Int
  targetHoursCapacity Float     
  
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id])
  
  // Checklist
  hasDrawings         Boolean   @default(false)
  hasMaterials        Boolean   @default(false)
  hasTools            Boolean   @default(false)
  hasSubcontractors   Boolean   @default(false)
  
  // Reporting end-of-week
  isSubmitted         Boolean   @default(false)
  isClosed            Boolean   @default(false) // For auto-closure Monday 07h00
  targetReached       Boolean?
  issuesReported      String?
  missedTargetReason  String?   
  workersCount        Float?    // Daily workforce logged by SM
  
  tasks               WeeklyPlanTask[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model WeeklyPlanTask {
  id                  String    @id @default(cuid())
  
  weeklyPlanId        String
  weeklyPlan          WeeklyPlan @relation(fields: [weeklyPlanId], references: [id])
  
  taskId              String
  task                Task       @relation(fields: [taskId], references: [id])
  
  plannedQuantity     Float
  actualQuantity      Float      @default(0) // Sum of daily progress
  locations           String?    

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model DailyReport {
  id                  String    @id @default(cuid())
  date                DateTime
  remarks             String?
  status              String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED
  
  lateReason          String?   // ABSENT, FORGOT, NO_CONNECTIVITY, OTHER
  lateDescription     String?
  workersCount        Int?      // Number of workers present that day
  
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id])
  
  siteManagerId       String
  
  attendance          Attendance[]
  taskProgress        DailyTaskProgress[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([projectId, date])
}

model Attendance {
  id                  String    @id @default(cuid())
  workerName          String
  hours               Float
  
  dailyReportId       String
  dailyReport         DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
}

model DailyTaskProgress {
  id                  String    @id @default(cuid())
  quantity            Float
  hours               Float?    // Option to track specific hours per task
  
  dailyReportId       String
  dailyReport         DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  
  taskId              String
  task                Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  blockageLog         BlockageLog?
}

model BlockageLog {
  id                    String    @id @default(cuid())
  reason                String    // SCOPE_CHANGE, REWORK, EMERGENCY, OTHER
  description           String
  
  dailyTaskProgressId   String    @unique
  dailyTaskProgress     DailyTaskProgress @relation(fields: [dailyTaskProgressId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime  @default(now())
}

model PhotoProof {
  id                  String    @id @default(cuid())
  url                 String    
  caption             String?
  
  createdAt           DateTime  @default(now())
}

model PlanTemplate {
  id                  String    @id @default(cuid())
  name                String
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User      @relation("templatesCreatedBy", fields: [createdById], references: [id])
  
  // JSON: Array of { taskId: string, quantity: number }
  taskSelections      String    // Stored as JSON

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Badge {
  id                  String    @id @default(cuid())
  code                String    @unique
  name                String
  description         String
  icon                String    // emoji or icon name
  category            String    // 'streak', 'milestone', 'performance'
  threshold           Int       @default(1)
  
  userBadges          UserBadge[]
}

model UserBadge {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId             String
  badge               Badge     @relation(fields: [badgeId], references: [id])
  
  earnedAt            DateTime  @default(now())

  @@unique([userId, badgeId])
}

// ==========================================
// COOKING APP MODELS
// ==========================================

model CookingProtocol {
  id          String   @id @default(cuid())
  name        String   // "Low-FODMAP", etc.
  description String?
  userId      String
  user        User     @relation("UserProtocols", fields: [userId], references: [id], onDelete: Cascade)
  startDate   DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
}

model PantryItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // 'Légumes', 'Épicerie', 'Produits Laitiers' etc.
  quantity    Float?
  unit        String?  // 'g', 'ml', 'pcs'
  userId      String
  user        User     @relation("UserPantry", fields: [userId], references: [id], onDelete: Cascade)
}

model CookingRecipe {
  id           String             @id @default(cuid())
  title        String
  description  String?
  imageUrl     String?
  instructions String?            // JSON string or long text
  ingredients  RecipeIngredient[]
  mealPreps    MealPrep[]
}

model RecipeIngredient {
  id          String        @id @default(cuid())
  name        String
  quantity    Float?
  unit        String?
  recipeId    String
  recipe      CookingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model MealPrep {
  id          String        @id @default(cuid())
  date        DateTime
  recipeId    String
  recipe      CookingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation("UserMealPreps", fields: [userId], references: [id], onDelete: Cascade)
}
